{
  "name": "opendesignguard",
  "title": "Open Design Guard",
  "description": "A paid remote MCP for agent design system guard MCP, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://opendesignguard.clauxel.com/",
  "documentationUrl": "https://opendesignguard.clauxel.com/mcp/",
  "endpointUrl": "https://opendesignguard.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://opendesignguard.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://opendesignguard.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://opendesignguard.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "starter",
        "name": "Starter",
        "monthlyUsd": 49
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 149
      },
      {
        "id": "studio",
        "name": "Studio",
        "monthlyUsd": 399
      }
    ]
  },
  "tools": [
    {
      "name": "check_design_guard",
      "description": "Open Design Guard check design guard",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "receipt_id": {
            "type": "string"
          },
          "usage_units": {
            "type": "integer"
          },
          "next_action": {
            "type": "string"
          }
        }
      }
    },
